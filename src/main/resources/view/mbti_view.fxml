<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="640.0" style="-fx-background-color: rgba(243,244,246,0.05);" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MBTIController">
    <children>
        <Pane prefHeight="10.0" style="-fx-background-color: #E5E7EB;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Pane fx:id="progressBar" prefHeight="10.0" prefWidth="0.0" style="-fx-background-color: linear-gradient(to right, #c73939, rgba(10,24,69,0.84)); -fx-background-radius: 0 5 5 0;" />
            </children>
        </Pane>

        <VBox fx:id="mainContainer" alignment="CENTER" layoutY="11.333333333333334" prefHeight="629.0" prefWidth="620.0" spacing="25.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="11.0">
            <children>

                <VBox fx:id="questionBox" alignment="CENTER" minHeight="160.0" prefHeight="247.0" prefWidth="589.0" style="-fx-background-color: white; -fx-background-radius: 15;">
                    <effect><DropShadow blurType="GAUSSIAN" color="#00000012" radius="15" /></effect>
                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <children>
                        <Label fx:id="questionLabel" prefHeight="167.0" prefWidth="529.0" text="加载中..." textAlignment="CENTER" wrapText="true">
                            <font><Font name="Microsoft YaHei UI Light" size="26.0" /></font>
                        </Label>
                    </children>
               <VBox.margin>
                  <Insets left="15.0" right="15.0" />
               </VBox.margin>
                </VBox>

                <VBox fx:id="optionBox" alignment="CENTER" prefHeight="259.0" prefWidth="620.0" spacing="15.0">
                    <children>
                        <Button fx:id="btnBack" onAction="#handleOption1" styleClass="back-btn">
                            <graphic>
                                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../images/backBtn.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <Button fx:id="btn1" onAction="#handleOptionA" prefHeight="50.0" prefWidth="475.0" style="-fx-background-color: #0a1845; -fx-background-radius: 25;" text="选项A" textFill="WHITE" />
                        <Button fx:id="btn3" onAction="#handleOptionC" prefHeight="50.0" prefWidth="475.0" style="-fx-background-color: rgba(199,57,57,0.1); -fx-background-radius: 25;" text="中立" />
                        <Button fx:id="btn2" onAction="#handleOptionB" prefHeight="50.0" prefWidth="475.0" style="-fx-background-color: white; -fx-border-color: #0a1845; -fx-border-radius: 25; -fx-background-radius: 25;" text="选项B" textFill="#c73939" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
